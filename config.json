{
  "name": "Guacamole",
  "version": "1.6.0",
  "slug": "haguacamole",
  "description": "Apache Guacamole is a clientless remote desktop gateway. It supports VNC, RDP and SSH.",
  "arch": [
    "aarch64",
    "amd64"
  ],
  "url": "https://guacamole.apache.org/",
  "startup": "application",
  "boot": "auto",
  "panel_icon": "mdi:remote-desktop",
  "ingress": true,
  "ingress_port": 8080,
  "image": "flcontainers/guacamole",
  "legacy": true,
  "map": [
    {
      "type": "homeassistant_config",
      "read_only": false,
      "path": "/config"
    }
  ],
  "ports": {
    "8080/tcp": null
  },
  "ports_description": {
    "8080/tcp": "Web interface, not required for Home Assistant ingress"
  },
  "options": {},
  "schema": {},
  "hassio_role": "default",
  "backup": "cold"
}
